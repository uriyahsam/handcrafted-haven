# ============================================================
# Handcrafted Haven — Environment Variables
# ============================================================

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/handcrafted_haven?sslmode=require"

# --- NextAuth ---
# Generate a secret: run `openssl rand -base64 32` in terminal
NEXTAUTH_SECRET="REPLACE_WITH_YOUR_SECRET"
NEXTAUTH_URL="http://localhost:3000"
# On Vercel, NEXTAUTH_URL is set automatically — you can omit it there.
